{
  "_version": "1.83.0",
  "sap.app": {
    "id": "zmanageleaverequest",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.22.0",
      "toolsId": "d78d167b-c755-4914-aac3-40c88b1a5386"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v2/srv/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "2.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "leaveRequest-manage": {
          "semanticObject": "leaveRequest",
          "action": "manage",
          "title": "{{leaveRequest-manage.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "config": {
      "fillWidth": true
    },
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "zmanageleaverequest.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "zmanageleaverequest.view",
        "async": true,
        "viewPath": "zmanageleaverequest.view"
      },
      "routes": [
        {
          "name": "RouteMaster",
          "pattern": ":?query:",
          "target": [
            "TargetMaster"
          ]
        }
      ],
      "targets": {
        "TargetMaster": {
          "id": "Master",
          "name": "Master"
        }
      }
    },
    "rootView": {
      "viewName": "zmanageleaverequest.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
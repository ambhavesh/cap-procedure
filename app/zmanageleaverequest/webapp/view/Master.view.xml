<mvc:View
    controllerName="zmanageleaverequest.controller.Master"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:smarttable="sap.ui.comp.smarttable"
    xmlns:smartfilterbar="sap.ui.comp.smartfilterbar"
    xmlns:smartvariants="sap.ui.comp.smartvariants"
    xmlns="sap.m"
>
    <f:DynamicPage
        id="page"
        showFooter="true"
    >
        <!-- <f:title>
            <f:DynamicPageTitle id="pageTitle">
                <f:heading>
                    <smartvariants:SmartVariantManagement
                        id="smartVariant"
                        persistencyKey="zmanageleaverequest.svm"
                    />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title> -->
        <f:header>
            <f:DynamicPageHeader>
                <smartfilterbar:SmartFilterBar
                    id="smartFilterBar"
                    entitySet="LeaveRequestSet"
                    smartVariant="smartVariant"
                    persistencyKey="zmanageleaverequest.sfb"
                    showFilterConfiguration="false"
                >
                    <smartfilterbar:controlConfiguration>
                        <smartfilterbar:ControlConfiguration
                            index="1"
                            key="leaveType"
                            label="Leave Type"
                            visibleInAdvancedArea="true"
                        />

                        <smartfilterbar:ControlConfiguration
                            index="2"
                            key="priority"
                            label="Priority"
                            visibleInAdvancedArea="true"
                            controlType="dropDownList"
                        />
                    </smartfilterbar:controlConfiguration>
                </smartfilterbar:SmartFilterBar>
            </f:DynamicPageHeader>
        </f:header>
        <f:content>
            <smarttable:SmartTable
                id="smartTable"
                entitySet="LeaveRequestSet"
                tableBindingPath="/LeaveRequestSet"
                header="Request"
                showRowCount="true"
                smartFilterId="smartFilterBar"
                tableType="ResponsiveTable"
                enableAutoBinding="true"
                enableAutoColumnWidth="true"
                smartVariant="smartVariant"
                enableExport="true"
                enableCopy="false"
                useTablePersonalisation="true"
                beforeRebindTable="onBeforeRebindTable"
                persistencyKey="zmanageleaverequest.st"
                ignoreFromPersonalisation="leaveTypeDesc"
                initiallyVisibleFields="leaveType,reason,fromDate,toDate,status,isHalfDay"
            >
                <Table
                    id="leaveRequestTable"
                    mode="MultiSelect"
                    sticky="ColumnHeaders,HeaderToolbar"
                    selectionChange="onSelectionChange"
                >
                    <noData>
                        <IllustratedMessage />
                    </noData>
                    <columns>
                        <Column>
                            <customData>
                                <core:CustomData
                                    key="p13nData"
                                    value='{"columnKey":"leaveType","leadingProperty":"leaveType","sortProperty":"leaveType","filterProperty":"leaveType"}'
                                />
                            </customData>
                            <header>
                                <Label
                                    text="Leave Type"
                                    design="Bold"
                                    wrapping="true"
                                />
                            </header>
                        </Column>
                        <Column>
                            <customData>
                                <core:CustomData
                                    key="p13nData"
                                    value='{"columnKey":"reason","leadingProperty":"reason","sortProperty":"reason","filterProperty":"reason"}'
                                />
                            </customData>
                            <header>
                                <Label
                                    text="Reason"
                                    design="Bold"
                                    wrapping="true"
                                />
                            </header>
                        </Column>
                        <Column>
                            <customData>
                                <core:CustomData
                                    key="p13nData"
                                    value='{"columnKey":"fromDate","leadingProperty":"fromDate","sortProperty":"fromDate","filterProperty":"fromDate"}'
                                />
                            </customData>
                            <header>
                                <Label
                                    text="From"
                                    design="Bold"
                                    wrapping="true"
                                />
                            </header>
                        </Column>
                        <Column>
                            <customData>
                                <core:CustomData
                                    key="p13nData"
                                    value='{"columnKey":"toDate","leadingProperty":"toDate","sortProperty":"toDate","filterProperty":"toDate"}'
                                />
                            </customData>
                            <header>
                                <Label
                                    text="To"
                                    design="Bold"
                                    wrapping="true"
                                />
                            </header>
                        </Column>
                        <Column>
                            <customData>
                                <core:CustomData
                                    key="p13nData"
                                    value='{"columnKey":"status","leadingProperty":"status","sortProperty":"status","filterProperty":"status"}'
                                />
                            </customData>
                            <header>
                                <Label
                                    text="Status"
                                    design="Bold"
                                    wrapping="true"
                                />
                            </header>
                        </Column>
                        <Column>
                            <customData>
                                <core:CustomData
                                    key="p13nData"
                                    value='{"columnKey":"isHalfDay","leadingProperty":"isHalfDay","sortProperty":"isHalfDay","filterProperty":"isHalfDay"}'
                                />
                            </customData>
                            <header>
                                <Label
                                    text="Is Half Day"
                                    design="Bold"
                                    wrapping="true"
                                />
                            </header>
                        </Column>
                    </columns>
                    <ColumnListItem>
                        <Text text="{leaveType}"/>
                        <Text text="{reason}" />
                        <Text
                            text="{path:'fromDate',type:'sap.ui.model.type.Date',formatOptions:{pattern:'dd-MM-yyyy'}}"
                        />
                        <Text
                            text="{path:'toDate',type:'sap.ui.model.type.Date',formatOptions:{pattern:'dd-MM-yyyy'}}"
                        />
                        <Text text="{status}" />
                        <Text text="{=${isHalfDay} ? 'Yes' : 'No'}" />
                    </ColumnListItem>
                </Table>
            </smarttable:SmartTable>
        </f:content>
    </f:DynamicPage>
</mvc:View>
